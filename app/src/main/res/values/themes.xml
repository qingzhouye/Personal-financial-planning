<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="Theme.LoanManager" parent="Theme.Material3.Light">
        <!-- Enable ActionBar (Material3 disables it by default) -->
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        
        <!-- Status bar color -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:navigationBarColor">@color/primary_dark</item>
        
        <!-- Window background -->
        <item name="android:windowBackground">@drawable/gradient_background</item>
        
        <!-- Text colors -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>
    
    <!-- Deep Blue Business Theme -->
    <style name="Theme.LoanManager.Blue" parent="Theme.Material3.Light">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="colorPrimary">#1565C0</item>
        <item name="colorPrimaryDark">#0D47A1</item>
        <item name="colorAccent">#42A5F5</item>
        <item name="android:statusBarColor">#0D47A1</item>
        <item name="android:navigationBarColor">#0D47A1</item>
        <item name="android:windowBackground">@drawable/gradient_background_blue</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Warm Orange Theme -->
    <style name="Theme.LoanManager.Orange" parent="Theme.Material3.Light">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="colorPrimary">#E65100</item>
        <item name="colorPrimaryDark">#BF360C</item>
        <item name="colorAccent">#FF9800</item>
        <item name="android:statusBarColor">#BF360C</item>
        <item name="android:navigationBarColor">#BF360C</item>
        <item name="android:windowBackground">@drawable/gradient_background_orange</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Purple Elegant Theme -->
    <style name="Theme.LoanManager.Purple" parent="Theme.Material3.Light">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="colorPrimary">#6A1B9A</item>
        <item name="colorPrimaryDark">#4A148C</item>
        <item name="colorAccent">#CE93D8</item>
        <item name="android:statusBarColor">#4A148C</item>
        <item name="android:navigationBarColor">#4A148C</item>
        <item name="android:windowBackground">@drawable/gradient_background_purple</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Deep Green Nature Theme -->
    <style name="Theme.LoanManager.Green" parent="Theme.Material3.Light">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="colorPrimary">#2E7D32</item>
        <item name="colorPrimaryDark">#1B5E20</item>
        <item name="colorAccent">#66BB6A</item>
        <item name="android:statusBarColor">#1B5E20</item>
        <item name="android:navigationBarColor">#1B5E20</item>
        <item name="android:windowBackground">@drawable/gradient_background_green</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Rose Pink Theme -->
    <style name="Theme.LoanManager.Rose" parent="Theme.Material3.Light">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="colorPrimary">#AD1457</item>
        <item name="colorPrimaryDark">#880E4F</item>
        <item name="colorAccent">#F48FB1</item>
        <item name="android:statusBarColor">#880E4F</item>
        <item name="android:navigationBarColor">#880E4F</item>
        <item name="android:windowBackground">@drawable/gradient_background_rose</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
    </style>

    <!-- Theme without ActionBar -->
    <style name="Theme.LoanManager.NoActionBar" parent="Theme.LoanManager">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    
    <!-- Card Style -->
    <style name="CardStyle">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">8dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardBackgroundColor">@color/card_background</item>
    </style>
    
    <!-- Stat Card Style -->
    <style name="StatCardStyle">
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">4dp</item>
        <item name="contentPadding">12dp</item>
    </style>
    
    <!-- Button Styles -->
    <style name="PrimaryButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">25dp</item>
        <item name="android:paddingStart">32dp</item>
        <item name="android:paddingEnd">32dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>
    
    <style name="SuccessButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/success</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">@dimen/spacing_sm</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>
    
    <style name="DangerButton" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/danger</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="cornerRadius">@dimen/spacing_sm</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>
    
    <style name="SecondaryButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">@dimen/spacing_sm</item>
        <item name="android:minHeight">@dimen/button_height</item>
    </style>
    
    <!-- Input Style -->
    <style name="InputStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_border</item>
        <item name="boxStrokeWidth">2dp</item>
        <item name="boxCornerRadiusTopStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusTopEnd">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomStart">@dimen/input_corner_radius</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/input_corner_radius</item>
    </style>
    
    <!-- Text Styles -->
    <style name="TitleText">
        <item name="android:textSize">@dimen/text_title</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="CardTitleText">
        <item name="android:textSize">@dimen/text_xl</item>
        <item name="android:textColor">@color/primary_dark</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="StatValueText">
        <item name="android:textSize">@dimen/text_xxl</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="StatLabelText">
        <item name="android:textSize">@dimen/text_sm</item>
        <item name="android:textColor">@color/semi_transparent_white</item>
    </style>
</resources>
