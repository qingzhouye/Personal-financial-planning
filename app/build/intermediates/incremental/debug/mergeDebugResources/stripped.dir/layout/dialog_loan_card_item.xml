<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="4dp"
    android:paddingVertical="4dp">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="@dimen/card_corner_radius"
        app:cardElevation="3dp"
        app:cardBackgroundColor="@android:color/transparent">

        <LinearLayout
            android:id="@+id/cardContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/gradient_primary"
            android:padding="@dimen/spacing_lg">

            <!-- 第一行：图标 + 贷款名称 + 状态标签 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvLoanIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="22sp"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/tvLoanName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_xl"
                    android:textStyle="bold"
                    android:textColor="@color/text_white" />

                <TextView
                    android:id="@+id/tvLoanStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/text_white"
                    android:background="@drawable/gradient_success"
                    android:paddingHorizontal="@dimen/spacing_sm"
                    android:paddingVertical="2dp"
                    android:visibility="gone" />
            </LinearLayout>

            <!-- 第二行：还款方式 -->
            <TextView
                android:id="@+id/tvRepaymentMethod"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/semi_transparent_white" />

            <!-- 分隔线 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_md"
                android:background="#40FFFFFF" />

            <!-- 第三行：月供 + 剩余本金 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="当前月供"
                        android:textSize="@dimen/text_xs"
                        android:textColor="#B0FFFFFF" />

                    <TextView
                        android:id="@+id/tvMonthlyPayment"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="剩余本金"
                        android:textSize="@dimen/text_xs"
                        android:textColor="#B0FFFFFF" />

                    <TextView
                        android:id="@+id/tvRemainingPrincipal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textSize="@dimen/text_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_white" />
                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>
